  /**
   * 深色模式 - 错误位置颜色
   */
  static readonly COLOR_MISPLACED_DARK: string = '#CA8A04';

  /**
   * 深色模式 - 不存在颜色
   */
  static readonly COLOR_ABSENT_DARK: string = '#4B5563';
